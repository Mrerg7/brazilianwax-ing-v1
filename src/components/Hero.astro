---
import { ACQUISITION_MAILTO } from '../config/site';
---

<header class="max-w-5xl mx-auto px-6 pt-20 pb-16 md:pt-24 md:pb-20 text-center">
  <div class="inline-flex items-center gap-x-2 mb-6">
    <div class="modern-pill flex items-center gap-x-2 px-4 py-1 rounded-2xl text-xs font-bold tracking-[1px]">
      <i class="fa-solid fa-search fa-xs"></i>
      <span>EXACT MATCH • HIGH INTENT</span>
    </div>
  </div>

  <h1 class="domain-hero tracking-tighter mb-4">brazilianwax.ing</h1>

  <p class="max-w-2xl mx-auto text-2xl md:text-3xl font-semibold tracking-tight text-[#4A5D4A] mb-5">
    The clean, modern domain with<br class="hidden md:block">SEO built directly into the name.
  </p>

  <p class="max-w-md mx-auto text-lg text-[#5C5C5C] mb-10">
    Own the exact phrase clients search for most in professional waxing. Short, memorable, and perfectly positioned.
  </p>

  <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
    <a href={ACQUISITION_MAILTO}
       class="group inline-flex items-center justify-center gap-x-3 px-6 sm:px-9 py-4 bg-brand-500 hover:bg-brand-600 text-white font-semibold text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-brand-500/20">
      <span>Inquire to Acquire</span>
      <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
    </a>

    <a href="#value"
       class="inline-flex items-center justify-center px-5 sm:px-8 py-4 border border-[#D4C9B8] hover:bg-white text-[#4A5D4A] font-semibold text-lg rounded-3xl transition-all">
      Explore the Opportunity
    </a>
  </div>
</header>
